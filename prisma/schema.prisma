// Banco Hostinger — espelho do sistema Alex (dump + app PHP)

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Inventario {
  id              Int     @id @default(autoincrement())
  status          String  @db.VarChar(50)
  nome            String  @db.VarChar(50)
  telefone        String  @db.VarChar(50)
  cpfCnpj         String? @map("cpf-cnpj") @db.VarChar(50)
  endereco        String  @db.VarChar(50)
  bairro          String  @db.VarChar(50)
  numero          String  @db.VarChar(50)
  cep             String  @db.VarChar(50)
  dataVisita      String  @map("data-visita") @db.VarChar(50)
  horaVisita      String  @map("hora-visita") @db.VarChar(50)
  observacao      String? @db.LongText
  funcionario     Int?
  valor           Decimal @default(0.00) @db.Decimal(10, 2)
  descontoPercent Decimal @default(0.00) @map("desconto_percent") @db.Decimal(5, 2)
  formaPagamento  String? @map("forma_pagamento") @db.VarChar(20)
  dataMontagem    String? @map("data-montagem") @db.VarChar(50)
  orcamento       String? @db.LongText

  @@map("inventario")
}

model Usuario {
  id           Int      @id @default(autoincrement())
  thumb        String   @db.VarChar(255)
  nome         String   @db.VarChar(255)
  usuario      String   @db.VarChar(255)
  senha        String   @db.LongText
  email        String   @db.VarChar(255)
  nivel        String   @db.VarChar(255)
  valorDiario  Decimal  @default(0.00) @map("valor_diario") @db.Decimal(10, 2)
  fornecedorId Int?     @map("fornecedor_id")

  @@map("usuarios")
}

model ProdutoSite {
  id        Int      @id @default(autoincrement())
  nome      String   @db.VarChar(120)
  slug      String   @unique @db.VarChar(120)
  descricao String?  @db.VarChar(500)
  ativo     Int      @default(1) @db.TinyInt
  ordem     Int      @default(0)
  criadoEm  DateTime @default(now()) @map("criado_em")
  atualizadoEm DateTime @default(now()) @updatedAt @map("atualizado_em")
  fotos     ProdutoFoto[]

  @@map("produtos_site")
}

model ProdutoFoto {
  id        Int      @id @default(autoincrement())
  produtoId Int      @map("produto_id")
  arquivo   String   @db.VarChar(255)
  legenda   String?  @db.VarChar(255)
  ehCapa    Int      @default(0) @map("eh_capa") @db.TinyInt
  ordem     Int      @default(0)
  criadoEm  DateTime @default(now()) @map("criado_em")
  produto   ProdutoSite @relation(fields: [produtoId], references: [id], onDelete: Cascade)

  @@map("produto_fotos")
}

model Material {
  id                Int      @id @default(autoincrement())
  material          String?  @db.VarChar(50)
  valorCusto        Decimal  @default(0.00) @map("valor_custo") @db.Decimal(10, 2)
  valor             Decimal  @default(0.00) @db.Decimal(10, 2)
  fornecedorId      Int?     @map("fornecedor_id")
  visivelFornecedor Int      @default(0) @map("visivel_fornecedor") @db.TinyInt
  valorFornecedor   Decimal  @default(0.00) @map("valor_fornecedor") @db.Decimal(10, 2)

  @@map("materiais")
}

model Fornecedor {
  id                Int      @id @default(autoincrement())
  razaoSocial       String   @map("razao_social") @db.VarChar(255)
  nomeFantasia      String?  @map("nome_fantasia") @db.VarChar(255)
  cnpj              String   @db.VarChar(18)
  inscricaoEstadual String?  @map("inscricao_estadual") @db.VarChar(50)
  email             String?  @db.VarChar(255)
  telefone          String?  @db.VarChar(50)
  contatoNome       String?  @map("contato_nome") @db.VarChar(255)
  cep               String?  @db.VarChar(10)
  endereco          String?  @db.VarChar(255)
  numero            String?  @db.VarChar(20)
  complemento       String?  @db.VarChar(100)
  bairro            String?  @db.VarChar(100)
  cidade            String?  @db.VarChar(100)
  uf                String?  @db.Char(2)
  observacao        String?  @db.Text
  criadoEm          DateTime @default(now()) @map("criado_em")
  atualizadoEm      DateTime @default(now()) @updatedAt @map("atualizado_em")

  @@map("fornecedores")
}

model AdminLog {
  id           BigInt   @id @default(autoincrement()) @db.UnsignedBigInt
  nivel        String   @default("info") @db.VarChar(20)
  mensagem     String   @db.VarChar(500)
  comoResolver String?  @map("como_resolver") @db.Text
  contexto     String?  @db.Text
  pagina       String?  @db.VarChar(500)
  usuarioId    Int?     @map("usuario_id") @db.UnsignedInt
  usuarioNome  String?  @map("usuario_nome") @db.VarChar(255)
  ip           String?  @db.VarChar(45)
  criadoEm     DateTime @default(now()) @map("criado_em")

  @@index([nivel])
  @@index([criadoEm])
  @@map("admin_logs")
}
