# Vercel: configure as Environment Variables (Production + Preview):
# DB_HOST, DB_PORT, DB_USER, DB_PASSWORD, DB_NAME, AUTH_SECRET
# Opcional: VITE_RADIO_STREAM, VITE_USER_THUMB_BASE

# Opcional: pasta de upload de fotos (padrão: public/images/produtos)
# PRODUTOS_UPLOAD_DIR=C:\caminho\para\Alex\app\public\images\produtos
# URL base para imagens padrão quando não há foto na galeria (ex.: site publicado)
# PRODUTOS_FALLBACK_BASE=https://alexcalhas.com

# Opcional: uma estação no painel (padrão: Hunter FM Pop 2000)
# VITE_RADIO_STREAM=https://live.hunter.fm/pop2k_normal
# VITE_RADIO_STREAM_FALLBACK=https://live.hunter.fm/pop2k_high

# Opcional: pasta de fotos de perfil (padrão: public/images/thumb)
# USER_THUMB_DIR=C:\caminho\para\Alex\app\public\images\thumb
# Opcional: fotos antigas ainda no servidor Alex (fallback se não achar local)
# VITE_USER_THUMB_BASE=https://seu-dominio.com/app/public/images/thumb
